Package: Cond2ST
Type: Reproducibility
Title: General Frameworks for Conditional Two-Sample Testing
Version: 1.0.0
Authors@R: c(
    person("Seongchan", "Lee", role = c("aut"),
           email = "statchan1106@yonsei.ac.kr"),
    person("Suman", "Cha", role = c("aut", "cre"),
           email = "oldrain123@yonsei.ac.kr"),
